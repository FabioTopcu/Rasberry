</style>
<script>
function showSection(id){document.getElementById('home').classList.add('hidden');document.getElementById('temp').classList.add('hidden');document.getElementById(id).classList.remove('hidden');}
async function fetchStatus(){try{const res=await fetch('/status.json');if(!res.ok)throw new Error('Netzwerkfehler');const data=await res.json();document.getElementById('cpu-bar').style.width=data.cpu+'%';document.getElementById('cpu-label').textContent='CPU: '+data.cpu+'%';document.getElementById('ram-bar').style.width=data.ram+'%';document.getElementById('ram-label').textContent='RAM: '+data.ram+'%';document.getElementById('temp-bar').style.width=(data.temp*2)+'%';document.getElementById('temp-label').textContent='Temperatur: '+data.temp+'°C';}catch(e){console.error(e);}}
setInterval(fetchStatus,5000);window.onload=()=>{fetchStatus();showSection('home');};
</script>
</head>
<body>
